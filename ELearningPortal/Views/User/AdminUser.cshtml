<div class="hidden fixed inset-0 z-[100]" id="modal-container">
    <!-- Modal Backdrop -->
    <div class="absolute inset-0 bg-on-surface/40 backdrop-blur-sm modal-close-trigger"></div>
    <!-- Add/Edit User Modal -->
    <div class="hidden relative w-full max-w-2xl bg-white rounded-xl shadow-lg overflow-hidden flex flex-col mx-auto mt-20 z-10 animate-in fade-in zoom-in duration-200" id="user-modal">
        <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center">
            <h2 class="font-title-lg text-title-lg text-on-surface" id="modal-title">Add User</h2>
            <button class="material-symbols-outlined text-on-surface-variant hover:bg-surface-container rounded-full p-1 modal-close-trigger">close</button>
        </div>
        <form id="user-form">
            <div class="p-6 overflow-y-auto max-h-[70vh] custom-scrollbar space-y-4">
                <div class="space-y-1">
                    <label class="text-label-md text-on-surface-variant font-medium">Profile Image:</label>
                    <div class="flex items-center gap-3 p-2 border border-outline-variant rounded-lg">
                        <button class="px-4 py-1.5 bg-surface-container-low border border-outline-variant rounded text-body-md" type="button">Choose File</button>
                        <span class="text-body-md text-outline">No file chosen</span>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">First Name <span class="text-error">*</span></label>
                        <input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-first-name" name="firstName" placeholder="Enter First Name" required="" type="text" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">Last Name <span class="text-error">*</span></label>
                        <input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-last-name" name="lastName" placeholder="Enter Last Name" required="" type="text" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">Email address <span class="text-error">*</span></label>
                        <input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-email" name="email" placeholder="Enter email" required="" type="email" />
                    </div>
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">Password <span class="text-error">*</span></label>
                        <input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-password" name="password" placeholder="Enter Password" type="password" />
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">Role <span class="text-error">*</span></label>
                        <select class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-role" name="role">
                            <option value="">Choose role...</option>
                            <option value="Super Admin">Super Admin</option>
                            <option value="Manager">Manager</option>
                            <option value="Student">Student</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-label-md text-on-surface-variant font-medium">Status <span class="text-error">*</span></label>
                        <select class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-status" name="status">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-label-md text-on-surface-variant font-medium">Phone Number <span class="text-error">*</span></label>
                    <input class="w-full px-4 py-2 border border-outline-variant rounded-lg text-body-md focus:ring-2 focus:ring-primary/20 focus:border-primary" id="input-phone" name="phone" placeholder="Enter Phone Number" required="" type="tel" />
                </div>
            </div>
            <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex justify-end gap-3">
                <button class="px-6 py-2 bg-secondary text-white rounded-lg font-title-md hover:bg-secondary/90 transition-colors modal-close-trigger" type="button">Close</button>
                <button class="px-6 py-2 bg-primary text-white rounded-lg font-title-md hover:bg-primary-container transition-all" type="submit">Save changes</button>
            </div>
        </form>
    </div>
    <!-- Delete Confirmation Modal -->
    <div class="hidden relative w-full max-w-md bg-white rounded-xl shadow-lg overflow-hidden flex flex-col mx-auto mt-40 z-10 animate-in fade-in zoom-in duration-200" id="delete-modal">
        <div class="p-6 text-center space-y-4">
            <div class="w-16 h-16 bg-error/10 text-error rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="material-symbols-outlined text-4xl">delete_forever</span>
            </div>
            <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">Confirm Delete</h3>
            <p class="text-body-lg text-on-surface-variant">Are you sure you want to delete this user? This action cannot be undone.</p>
        </div>
        <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex justify-center gap-3">
            <button class="px-6 py-2 bg-outline-variant text-on-surface font-title-md rounded-lg hover:bg-outline-variant/80 transition-colors modal-close-trigger" type="button">Cancel</button>
            <button class="px-6 py-2 bg-error text-white rounded-lg font-title-md hover:bg-error/90 transition-all" id="confirm-delete-btn" type="button">Yes, Delete</button>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const modalContainer = document.getElementById('modal-container');
        const userModal = document.getElementById('user-modal');
        const deleteModal = document.getElementById('delete-modal');
        const modalTitle = document.getElementById('modal-title');
        const userForm = document.getElementById('user-form');

        let activeUserId = null;

        // Open Modal Helper
        const openModal = (type) => {
            modalContainer.classList.remove('hidden');
            modalContainer.classList.add('flex');
            document.body.classList.add('overflow-hidden');

            if (type === 'user') {
                userModal.classList.remove('hidden');
                deleteModal.classList.add('hidden');
            } else if (type === 'delete') {
                deleteModal.classList.remove('hidden');
                userModal.classList.add('hidden');
                deleteModal.classList.add('flex');
            }
        };

        // Close Modals Helper
        const closeModals = () => {
            modalContainer.classList.add('hidden');
            modalContainer.classList.remove('flex');
            userModal.classList.add('hidden');
            deleteModal.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
            userForm.reset();
            activeUserId = null;
        };

        // Add User Button Click (Main Header & Sidebar)
        const addButtons = ['add-user-btn', 'sidebar-add-btn'];
        addButtons.forEach(id => {
            const btn = document.getElementById(id);
            if (btn) {
                btn.addEventListener('click', () => {
                    modalTitle.innerText = 'Add User';
                    openModal('user');
                });
            }
        });

        // Table Action Delegations (Edit / Delete)
        const table = document.getElementById('user-table');
        if (table) {
            table.addEventListener('click', (e) => {
                const row = e.target.closest('tr');
                if (!row) return;

                const userId = row.getAttribute('data-user-id');

                // Edit Click
                if (e.target.closest('.edit-user-btn')) {
                    activeUserId = userId;
                    modalTitle.innerText = 'Edit User';

                    // Pre-fill data
                    const fullName = row.querySelector('.user-name').innerText;
                    const email = row.querySelector('.user-email').innerText;
                    const phone = row.querySelector('.user-phone').innerText;
                    const role = row.querySelector('.user-role').innerText;
                    const status = row.querySelector('.user-status-text').innerText;

                    const nameParts = fullName.split(' ');
                    document.getElementById('input-first-name').value = nameParts[0] || '';
                    document.getElementById('input-last-name').value = nameParts.slice(1).join(' ') || '';
                    document.getElementById('input-email').value = email;
                    document.getElementById('input-phone').value = phone;

                    // Select Role
                    const roleSelect = document.getElementById('input-role');
                    Array.from(roleSelect.options).forEach(opt => {
                        if (opt.value === role) opt.selected = true;
                    });

                    // Select Status
                    const statusSelect = document.getElementById('input-status');
                    Array.from(statusSelect.options).forEach(opt => {
                        if (opt.value === status) opt.selected = true;
                    });

                    openModal('user');
                }

                // Delete Click
                if (e.target.closest('.delete-user-btn')) {
                    activeUserId = userId;
                    openModal('delete');
                }
            });
        }

        // Close triggers
        document.querySelectorAll('.modal-close-trigger').forEach(trigger => {
            trigger.addEventListener('click', closeModals);
        });

        // Form Submission (Simulated)
        userForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const formData = new FormData(userForm);
            console.log('Saving User Data:', Object.fromEntries(formData));
            // In a real app, you'd send this to your API
            closeModals();
            alert('User saved successfully!');
        });

        // Confirm Delete (Simulated)
        document.getElementById('confirm-delete-btn').addEventListener('click', () => {
            console.log('Deleting User ID:', activeUserId);
            // In a real app, find and remove row or call API
            const rowToRemove = document.querySelector(`tr[data-user-id="${activeUserId}"]`);
            if (rowToRemove) rowToRemove.remove();

            closeModals();
        });

        // Original Search Simulation Logic
        const searchInput = document.querySelector('input[placeholder*="Search students"]');
        if(searchInput) {
            searchInput.addEventListener('input', (e) => {
                const tableContainer = document.querySelector('table').closest('.bg-surface-container-lowest');
                const emptyState = document.getElementById('no-students-found');

                if (e.target.value === 'show_empty') {
                    tableContainer.classList.add('hidden');
                    emptyState.classList.remove('hidden');
                    emptyState.classList.add('flex');
                } else {
                    tableContainer.classList.remove('hidden');
                    emptyState.classList.add('hidden');
                    emptyState.classList.remove('flex');
                }
            });
        }
    });
</script>