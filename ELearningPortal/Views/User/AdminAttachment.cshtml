    <div class="absolute right-0 top-0 h-full w-full max-w-md bg-surface-container-lowest shadow-2xl flex flex-col transform transition-transform duration-300 translate-x-0">
        <div class="p-6 border-b border-outline-variant flex justify-between items-center bg-primary text-white">
            <div>
                <h3 class="font-title-lg">File Preview</h3>
                <p class="text-xs opacity-80">Metadata &amp; Overview</p>
            </div>
            <button class="p-2 hover:bg-white/10 rounded-full transition-colors" onclick="closeViewDrawer()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-6 flex-1 overflow-y-auto space-y-8">
            <div class="flex flex-col items-center text-center">
                <div class="w-32 h-40 bg-surface-container-low border border-outline-variant rounded-lg mb-4 flex items-center justify-center relative overflow-hidden group shadow-lg">
                    <span class="material-symbols-outlined text-6xl text-error">picture_as_pdf</span>
                    <div class="absolute inset-0 bg-primary/40 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-opacity cursor-zoom-in">
                        <span class="material-symbols-outlined text-white text-3xl">zoom_in</span>
                    </div>
                </div>
                <h4 class="font-bold text-lg mb-1">Notes - Lesson 1.pdf</h4>
                <span class="bg-error/10 text-error text-xs font-bold px-3 py-1 rounded-full">PDF Document</span>
            </div>
            <div class="space-y-4">
                <h5 class="text-sm font-bold uppercase tracking-wider text-outline">Details</h5>
                <div class="grid grid-cols-2 gap-y-4 text-sm">
                    <div class="text-on-surface-variant">Master Course</div>
                    <div class="font-bold text-right">Full Stack Java</div>
                    <div class="text-on-surface-variant">Sub Course</div>
                    <div class="font-bold text-right">Core Java</div>
                    <div class="text-on-surface-variant">Lesson</div>
                    <div class="font-bold text-right">OOPS Principles</div>
                    <div class="text-on-surface-variant">File Size</div>
                    <div class="font-bold text-right">2.4 MB</div>
                    <div class="text-on-surface-variant">Upload Date</div>
                    <div class="font-bold text-right">Oct 24, 2023</div>
                    <div class="text-on-surface-variant">Uploaded By</div>
                    <div class="font-bold text-right text-primary underline">Admin User</div>
