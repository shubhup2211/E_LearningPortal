            <span class="text-xs text-on-surface-variant font-medium bg-white px-3 py-1 rounded-full border border-outline-variant">Showing 10 of 1,248</span>
        </div>
        <div class="overflow-x-auto overflow-y-hidden">
            <!-- Desktop Table -->
            <table class="w-full text-left border-collapse hidden md:table">
                <thead class="bg-surface-container-low/20">
