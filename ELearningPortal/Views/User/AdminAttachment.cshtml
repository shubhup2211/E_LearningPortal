                                <div class="w-8 h-8 rounded bg-error/10 text-error flex items-center justify-center">
                                    <span class="material-symbols-outlined text-sm">picture_as_pdf</span>
                                </div>
                                <span class="font-bold text-on-surface">Notes - Lesson 1</span>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-on-surface-variant">Full Stack Java</td>
                        <td class="px-6 py-4 text-sm text-on-surface-variant truncate max-w-[150px]">OOPS Principles Intro</td>
                        <td class="px-6 py-4">
