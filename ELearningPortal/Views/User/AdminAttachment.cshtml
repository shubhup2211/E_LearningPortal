                        <button class="flex-1 py-2 bg-surface-container-low text-primary rounded-lg text-sm font-bold">View</button>
                        <button class="flex-1 py-2 bg-surface-container-low text-tertiary rounded-lg text-sm font-bold">Download</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 border-t border-outline-variant flex items-center justify-between">
            <div class="text-sm text-on-surface-variant hidden sm:block">
                Showing <span class="font-bold">1</span> to <span class="font-bold">10</span> of <span class="font-bold">1,248</span> entries
            </div>
            <div class="flex items-center gap-2">
                <button class="w-10 h-10 rounded-lg border border-outline-variant flex items-center justify-center text-outline hover:bg-surface-container-low transition-colors disabled:opacity-50" disabled="">
                    <span class="material-symbols-outlined">chevron_left</span>
                </button>
                <button class="w-10 h-10 rounded-lg bg-primary text-white flex items-center justify-center font-bold">1</button>
                <button class="w-10 h-10 rounded-lg border border-outline-variant flex items-center justify-center hover:bg-surface-container-low transition-colors font-bold">2</button>
                <button class="w-10 h-10 rounded-lg border border-outline-variant flex items-center justify-center hover:bg-surface-container-low transition-colors font-bold">3</button>
                <button class="w-10 h-10 rounded-lg border border-outline-variant flex items-center justify-center text-outline hover:bg-surface-container-low transition-colors">
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>
<!-- Modals and Overlays -->
<!-- Add Attachment Modal -->
<div class="fixed inset-0 z-[100] flex items-center justify-center hidden" id="addModal">
    <div class="modal-overlay absolute inset-0" onclick="closeAddModal()"></div>
    <div class="bg-surface-container-lowest w-full max-w-2xl rounded-2xl shadow-2xl z-10 overflow-hidden flex flex-col mx-4 max-h-[921px]">
        <div class="px-8 py-6 border-b border-outline-variant flex justify-between items-center bg-surface-container-low/30">
            <h3 class="font-headline-lg-mobile md:font-headline-lg text-primary">Add New Attachment</h3>
            <button class="p-2 hover:bg-error/10 text-outline hover:text-error rounded-full transition-colors" onclick="closeAddModal()">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8 overflow-y-auto space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="text-sm font-bold">Attachment Title*</label>
                    <input class="w-full px-4 py-2 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary/20 outline-none" placeholder="e.g. Lab Exercise 1" type="text" />
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-bold">Sub Course*</label>
                    <select class="w-full px-4 py-2 border border-outline-variant rounded-xl outline-none" disabled="" id="modalSub">
                        <option value="">Select Sub Course</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-sm font-bold">Lesson*</label>
                    <select class="w-full px-4 py-2 border border-outline-variant rounded-xl outline-none" disabled="" id="modalLesson">
                        <option value="">Select Lesson</option>
                    </select>
                </div>
            </div>
            <!-- Drag & Drop Area -->
            <div class="space-y-2">
                <label class="text-sm font-bold">Upload File</label>
                <div class="border-2 border-dashed border-outline-variant rounded-2xl p-10 flex flex-col items-center justify-center bg-surface-container-low/20 hover:border-primary hover:bg-primary/5 transition-all cursor-pointer group">
                    <div class="w-8 h-8 rounded-full bg-primary/10 text-primary flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined text-3xl">cloud_upload</span>
                    </div>
                    <p class="font-bold text-on-surface">Click to upload or drag and drop</p>
                    <p class="text-xs text-on-surface-variant mt-1">PDF, DOCX, ZIP or PPTX (Max 50MB)</p>
                </div>
            </div>
        </div>
        <div class="px-8 py-6 border-t border-outline-variant flex justify-end gap-4 bg-surface-container-low/30">
            <button class="px-6 py-2 border border-outline-variant rounded-xl font-bold hover:bg-surface-container-high transition-colors" onclick="closeAddModal()">Cancel</button>
            <button class="px-8 py-2 bg-primary text-white rounded-xl font-bold hover:bg-primary-container transition-colors shadow-lg">Save &amp; Upload</button>
        </div>
    </div>
</div>
<!-- View Attachment Drawer (Right Side) -->
