@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<!-- Page Header -->
<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Attachment Management</h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Manage learning attachment content for your branch.</p>
    </div>
    <button class="bg-primary text-white px-6 py-3 rounded-xl font-title-md flex items-center gap-2 hover:bg-primary-container transition-all shadow-lg shadow-primary/20" onclick="openAddModal()">
        <span class="material-symbols-outlined text-lg">add</span>
        Add Attachment
    </button>
</div>
<!-- Scrollable Content -->
<div class="flex-1 overflow-y-auto p-section-padding bg-background space-y-stack-lg">
    <!-- Summary Cards Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
        <!-- Total Attachments -->
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm flex items-center justify-between group hover:border-primary transition-all">
            <div>
                <p class="text-on-surface-variant text-label-md uppercase tracking-wider mb-1">Total Attachments</p>
                <h3 class="text-headline-lg font-bold">1,248</h3>
                <p class="text-xs text-tertiary flex items-center mt-2">
                    <span class="material-symbols-outlined text-sm mr-1">trending_up</span>
