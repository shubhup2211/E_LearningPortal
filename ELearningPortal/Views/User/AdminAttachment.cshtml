                            </button>
                            <button class="p-2 text-error hover:bg-error/10 rounded-lg transition-colors" onclick="openDeleteModal()" title="Delete">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </td>
                    </tr>
                    <!-- Skeleton Loading Row -->
                    <tr class="skeleton-row hidden">
                        <td class="px-6 py-4"><div class="h-4 w-32 skeleton rounded"></div></td>
                        <td class="px-6 py-4"><div class="h-4 w-24 skeleton rounded"></div></td>
                        <td class="px-6 py-4"><div class="h-4 w-20 skeleton rounded"></div></td>
                        <td class="px-6 py-4"><div class="h-6 w-12 skeleton rounded-full"></div></td>
                        <td class="px-6 py-4"><div class="h-4 w-12 skeleton rounded"></div></td>
                        <td class="px-6 py-4 text-right"><div class="h-8 w-24 skeleton rounded inline-block"></div></td>
                    </tr>
                </tbody>
            </table>
            <!-- Mobile List -->
