                <div class="p-4 space-y-3">
                    <div class="flex justify-between items-start">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded bg-error/10 text-error flex items-center justify-center">
                                <span class="material-symbols-outlined">picture_as_pdf</span>
                            </div>
                            <div>
                                <p class="font-bold">Notes - Lesson 1</p>
                                <p class="text-xs text-on-surface-variant">Full Stack Java • 2.4 MB</p>
                            </div>
                        </div>
                        <span class="bg-error/10 text-error text-[10px] font-bold px-2 py-0.5 rounded-full">PDF</span>
                    </div>
