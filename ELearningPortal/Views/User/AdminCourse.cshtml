<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        const content = modal.querySelector('div');

        if (modal.classList.contains('hidden')) {
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.add('opacity-100');
                content.classList.add('scale-100');
            }, 10);
        } else {
            modal.classList.remove('opacity-100');
            content.classList.remove('scale-100');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }
    }

    function toggleDrawer(id) {
        const drawer = document.getElementById(id);
        const overlay = drawer.querySelector('#drawerOverlay');
        const panel = drawer.querySelector('.translate-x-full, .translate-x-0');

        if (panel.classList.contains('translate-x-full')) {
            panel.classList.remove('translate-x-full');
            panel.classList.add('translate-x-0');
            overlay.classList.remove('pointer-events-none');
            overlay.classList.add('opacity-100', 'pointer-events-auto');
        } else {
            panel.classList.add('translate-x-full');
            panel.classList.remove('translate-x-0');
            overlay.classList.remove('opacity-100', 'pointer-events-auto');
            overlay.classList.add('pointer-events-none');
        }
    }

    // Search highlight micro-interaction
    document.querySelectorAll('input').forEach(input => {
        input.addEventListener('focus', () => {
            input.parentElement.classList.add('ring-2', 'ring-primary/20');
        });
        input.addEventListener('blur', () => {
            input.parentElement.classList.remove('ring-2', 'ring-primary/20');
        });
    });
</script>
