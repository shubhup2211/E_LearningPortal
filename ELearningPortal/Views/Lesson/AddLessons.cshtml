@using ELearning.Enums
@using ELearningPortal.Models.Course
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<partial name="Notification"></partial>

@model LessonView
<!-- Page Header -->
<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Lesson Management</h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mt-1">Manage learning videos and lesson content for your branch.</p>
    </div>
    <button class="bg-primary text-white px-6 py-3 rounded-xl font-title-md flex items-center gap-2 hover:bg-primary-container transition-all shadow-lg shadow-primary/20" onclick="toggleModal('addLessonModal')">
        <span class="material-symbols-outlined">add</span>
        Add Lesson
    </button>
</div>
<!-- Summary Statistics Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-4">
        <div class="w-12 h-12 bg-primary-fixed rounded-xl flex items-center justify-center text-primary">
            <span class="material-symbols-outlined">video_library</span>
        </div>
        <div>
            <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Total Lessons</p>
            <h3 class="text-title-lg font-bold">1,240</h3>
        </div>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-4">
        <div class="w-12 h-12 bg-tertiary-fixed-dim/20 rounded-xl flex items-center justify-center text-tertiary">
            <span class="material-symbols-outlined">check_circle</span>
        </div>
        <div>
            <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Published</p>
            <h3 class="text-title-lg font-bold">1,180</h3>
        </div>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-4">
        <div class="w-12 h-12 bg-error-container rounded-xl flex items-center justify-center text-error">
            <span class="material-symbols-outlined">pause_circle</span>
        </div>
        <div>
            <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Inactive</p>
            <h3 class="text-title-lg font-bold">60</h3>
        </div>
    </div>
    <div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/30 flex items-center gap-4">
        <div class="w-12 h-12 bg-secondary-fixed rounded-xl flex items-center justify-center text-secondary">
            <span class="material-symbols-outlined">schedule</span>
        </div>
        <div>
            <p class="text-label-md text-on-surface-variant uppercase tracking-wider">Avg Duration</p>
            <h3 class="text-title-lg font-bold">32 Min</h3>
        </div>
    </div>
</div>
<!-- Filter Panel -->
<div class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant/30 mb-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="space-y-1">
            <label class="text-label-md font-semibold text-on-surface-variant">Search</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
                <input class="w-full pl-9 pr-4 py-2 border border-outline-variant rounded-lg text-sm focus:ring-primary focus:border-primary" placeholder="Lesson ID or title..." type="text" />
            </div>
        </div>
        <div class="space-y-1">
            <label class="text-label-md font-semibold text-on-surface-variant">Master Course</label>
            <select class="w-full px-3 py-2 border border-outline-variant rounded-lg text-sm focus:ring-primary focus:border-primary">
                <option>All Master Courses</option>
                <option>Advanced Mathematics</option>
                <option>Quantum Physics</option>
                <option>Classical Literature</option>
            </select>
        </div>
        <div class="space-y-1">
            <label class="text-label-md font-semibold text-on-surface-variant">Sub Course</label>
            <select class="w-full px-3 py-2 border border-outline-variant rounded-lg text-sm focus:ring-primary focus:border-primary">
                <option>All Sub Courses</option>
                <option>Calculus III</option>
                <option>Linear Algebra</option>
            </select>
        </div>
        <div class="space-y-1">
            <label class="text-label-md font-semibold text-on-surface-variant">Status</label>
            <select class="w-full px-3 py-2 border border-outline-variant rounded-lg text-sm focus:ring-primary focus:border-primary">
                <option>All Status</option>
                <option>Active</option>
                <option>Inactive</option>
            </select>
        </div>
        <div class="space-y-1">
            <label class="text-label-md font-semibold text-on-surface-variant">Date Range</label>
            <input class="w-full px-3 py-2 border border-outline-variant rounded-lg text-sm focus:ring-primary focus:border-primary" type="date" />
        </div>
    </div>
</div>
<!-- Lesson Table Card -->
<div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden">
    <div class="px-6 py-4 border-b border-outline-variant/30 flex justify-between items-center">
        <h3 class="font-title-md text-on-surface">Lesson Inventory</h3>
        <div class="flex gap-2">
            <button class="p-2 text-outline hover:bg-surface-container-low rounded-lg transition-colors">
                <span class="material-symbols-outlined">filter_list</span>
            </button>
            <button class="p-2 text-outline hover:bg-surface-container-low rounded-lg transition-colors">
                <span class="material-symbols-outlined">download</span>
            </button>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead class="bg-surface-container-low">
                <tr>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Lesson Title</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Sub Course</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Duration</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Display Order</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Status</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant">Created Date</th>
                    <th class="px-6 py-4 font-title-md text-sm text-on-surface-variant text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant/20">
                @foreach (var item in Model.Lessonlist)
                {
                    <tr class="hover:bg-surface-container-low/50 transition-colors">
                        <td class="px-6 py-4">
                        <div class="flex items-center gap-3">                           
                            <span class="font-title-md text-sm text-on-surface">@item.LessonTitle</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-body-md text-on-surface-variant">@item.SubCourse.SubCourseName</td>
                    <td class="px-6 py-4 text-body-md text-on-surface-variant">@item.Duration</td>
                    <td class="px-6 py-4 text-body-md text-on-surface-variant">@item.DisplayOrder</td>
                    <td class="px-6 py-4">
                            @if (item.Status == Status.Active)
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-green-100 text-green-700 text-label-md font-bold">
                                    <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                    Active
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-red-100 text-red-700 text-label-md font-bold">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span>
                                    Inactive
                                </span>
                            }
                        </td>
                     <td class="px-6 py-4 text-body-md text-on-surface-variant">@item.CreatedAt</td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2">
                            <a class="p-2 text-outline hover:bg-surface-container-low rounded-lg transition-colors" asp-controller="Lesson" asp-action="EditLesson" asp-route-id="@item.LessonId">
                                <span class="material-symbols-outlined">edit</span>
                            </a>
                                <a class="p-2 text-error hover:bg-error/10 rounded-lg transition-colors" asp-controller="Lesson" asp-action="DeleteLesson" asp-route-id="@item.LessonId" onclick="return confirm('Are you sure you want to delete this Lesson?');">
                                <span class="material-symbols-outlined">delete</span>
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant/30 flex items-center justify-between">
        <span class="text-sm text-on-surface-variant font-body-md">Showing 1 to 10 of 1,240 lessons</span>
        <div class="flex gap-2">
            <button class="px-4 py-2 border border-outline-variant rounded-lg text-sm hover:bg-surface-container-lowest transition-colors">Previous</button>
            <button class="px-4 py-2 bg-primary text-white rounded-lg text-sm font-bold shadow-sm">1</button>
            <button class="px-4 py-2 border border-outline-variant rounded-lg text-sm hover:bg-surface-container-lowest transition-colors">2</button>
            <button class="px-4 py-2 border border-outline-variant rounded-lg text-sm hover:bg-surface-container-lowest transition-colors">3</button>
            <button class="px-4 py-2 border border-outline-variant rounded-lg text-sm hover:bg-surface-container-lowest transition-colors">Next</button>
        </div>
    </div>
</div>

<!-- Modal: Add Lesson -->
<div class="hidden fixed inset-0 z-50 overflow-y-auto" id="addLessonModal">
    <div class="flex items-center justify-center min-h-screen px-4 py-12">
        <div class="fixed inset-0 bg-on-background/60 backdrop-blur-sm" onclick="toggleModal('addLessonModal')"></div>
        <div class="relative bg-surface-container-lowest w-full max-w-3xl rounded-xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-300">
            <div class="p-6 border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
                <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">Add New Lesson</h3>
                <button class="text-outline hover:text-error transition-colors" onclick="toggleModal('addLessonModal')">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-8 space-y-6">
                <form asp-action="AddLessons" asp-controller="Lesson" method="post" >
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-label-md font-bold text-on-surface-variant">Sub Course</label>
                            <select asp-for="SubCourseId" asp-items="ViewBag.SubCourse" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary">
                        </select>
                            <span asp-validation-for="SubCourseId" class="text-danger"></span>
                    </div>
                        <div class="space-y-1">
                            <label class="text-label-md font-bold text-on-surface-variant">Status</label>
                            <select asp-for="Status" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary">
                                <option value="1">Active</option>
                                <option value="0">Inactive</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>
                </div>
                <div class="space-y-1">
                    <label class="text-label-md font-bold text-on-surface-variant">Lesson Title</label>
                        <input asp-for="LessonTitle" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary" placeholder="e.g. Fundamental Theorem of Calculus" type="text" />
                        <span asp-validation-for="LessonTitle" class="text-danger"></span>
                    </div>
                <div class="space-y-1">
                    <label class="text-label-md font-bold text-on-surface-variant">Video URL</label>
                    <div class="relative">
                            <input asp-for="VideoUrl" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary" placeholder="https://youtube.com/watch?v=..." type="text" />
                            <span asp-validation-for="VideoUrl" class="text-danger"></span>
                        </div>
                       
                </div>
                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-1">
                        <label class="text-label-md font-bold text-on-surface-variant">Duration (Min)</label>
                            <input asp-for="Duration" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary" placeholder="30" type="number" />
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>
                    <div class="space-y-1">
                        <label class="text-label-md font-bold text-on-surface-variant">Display Order</label>
                            <input asp-for="DisplayOrder" class="w-full px-4 py-3 border border-outline-variant rounded-xl focus:ring-2 focus:ring-primary" placeholder="1" type="number" />
                            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                    </div>
                </div>

            <div class="p-6 bg-surface-container-low border-t border-outline-variant/30 flex justify-end gap-3">
                <button class="px-6 py-2 border border-outline rounded-xl font-title-md hover:bg-white transition-colors" onclick="toggleModal('addLessonModal')">Cancel</button>
                <button type="submit" class="px-6 py-2 bg-primary text-white rounded-xl font-title-md hover:bg-primary-container shadow-lg shadow-primary/20 transition-all">Save Lesson</button>
            </div>
            </form>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleModal(id) {
        const modal = document.getElementById(id);
        modal.classList.toggle('hidden');
    }

    function toggleDrawer(id) {
        const drawer = document.getElementById(id);
        const content = document.getElementById('drawerContent');

        if (drawer.classList.contains('hidden')) {
            drawer.classList.remove('hidden');
            setTimeout(() => {
                content.classList.remove('translate-x-full');
            }, 10);
        } else {
            content.classList.add('translate-x-full');
            setTimeout(() => {
                drawer.classList.add('hidden');
            }, 300);
        }
    }
</script>
@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}