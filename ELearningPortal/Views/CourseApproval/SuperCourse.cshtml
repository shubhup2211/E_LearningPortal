@{
    Layout = "~/Views/Shared/_SuperAdminLayout.cshtml";
}
<div class="pt-10 px-section-padding pb-stack-lg">
    <div >
        <h2 class="font-headline-lg text-headline-lg text-on-surface">Course Approval</h2>
        <p class="text-on-surface-variant font-body-lg text-body-lg mt-1">Review and approve Courses submitted by Branch Admins.</p>
    </div><br />
    <!-- Summary Card Row (Bento Style) -->
    <div class="grid grid-cols-4 gap-gutter mb-stack-lg">
        <div class="bg-surface-container-lowest p-stack-lg rounded-lg elevation-1 border border-outline-variant flex items-center gap-stack-md transition-transform hover:scale-[1.02]">
            <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center text-primary">
                <span class="material-symbols-outlined" data-icon="auto_stories">auto_stories</span>
            </div>
            <div>
                <p class="text-label-md text-outline font-medium">Total Courses</p>
                <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">1,248</h3>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-stack-lg rounded-lg elevation-1 border-l-4 border-l-yellow-400 flex items-center gap-stack-md transition-transform hover:scale-[1.02]">
            <div class="w-12 h-12 rounded-full bg-yellow-100 flex items-center justify-center text-yellow-700">
                <span class="material-symbols-outlined" data-icon="pending">pending</span>
            </div>
            <div>
                <p class="text-label-md text-outline font-medium">Pending Approval</p>
                <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-yellow-700">42</h3>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-stack-lg rounded-lg elevation-1 border-l-4 border-l-tertiary flex items-center gap-stack-md transition-transform hover:scale-[1.02]">
            <div class="w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined" data-icon="check_circle">check_circle</span>
            </div>
            <div>
                <p class="text-label-md text-outline font-medium">Approved Courses</p>
                <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-tertiary">1,180</h3>
            </div>
        </div>
        <div class="bg-surface-container-lowest p-stack-lg rounded-lg elevation-1 border-l-4 border-l-error flex items-center gap-stack-md transition-transform hover:scale-[1.02]">
            <div class="w-12 h-12 rounded-full bg-error-container flex items-center justify-center text-error">
                <span class="material-symbols-outlined" data-icon="cancel">cancel</span>
            </div>
            <div>
                <p class="text-label-md text-outline font-medium">Rejected Courses</p>
                <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-error">26</h3>
