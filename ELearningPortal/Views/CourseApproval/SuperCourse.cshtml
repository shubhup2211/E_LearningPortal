        <div class="flex-1 min-w-[200px]">
            <label class="text-label-md text-outline mb-1 block">Branch</label>
            <select class="w-full bg-surface-container-low border-outline-variant rounded-lg text-body-md py-2 focus:ring-primary">
                <option>All Branches</option>
                <option>Central Branch</option>
                <option>North Campus</option>
                <option>Skyway Institute</option>
            </select>
        </div>
        <div class="flex-1 min-w-[150px]">
            <label class="text-label-md text-outline mb-1 block">Approval Status</label>
            <select class="w-full bg-surface-container-low border-outline-variant rounded-lg text-body-md py-2 focus:ring-primary">
                <option>Pending</option>
                <option>Approved</option>
                <option>Rejected</option>
            </select>
        </div>
        <div class="flex-1 min-w-[150px]">
            <label class="text-label-md text-outline mb-1 block">Course Status</label>
            <select class="w-full bg-surface-container-low border-outline-variant rounded-lg text-body-md py-2 focus:ring-primary">
                <option>Active</option>
                <option>Inactive</option>
            </select>
        </div>
        <div class="flex-1 min-w-[200px]">
            <label class="text-label-md text-outline mb-1 block">Date Range</label>
            <div class="relative">
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline text-[18px]" data-icon="calendar_today">calendar_today</span>
                <input class="w-full bg-surface-container-low border-outline-variant rounded-lg text-body-md py-2 pr-10 focus:ring-primary" type="text" value="Oct 01 - Oct 14, 2023" />
