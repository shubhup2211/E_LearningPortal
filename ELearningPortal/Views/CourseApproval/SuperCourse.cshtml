                            </div>
                            <div>
                                <p class="font-title-md text-on-surface">Full Stack Java Development</p>
                                <p class="text-label-md text-outline">Code: CS-204 | 12 Modules</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-container-margin py-4">
                        <span class="text-body-md text-on-surface-variant">Central Branch</span>
                    </td>
                    <td class="px-container-margin py-4">
                        <div class="flex flex-col">
                            <span class="text-body-md font-medium text-on-surface">Rahul Patil</span>
                            <span class="text-label-md text-outline">Branch Admin</span>
                        </div>
                    </td>
                    <td class="px-container-margin py-4">
                        <span class="bg-yellow-100 text-yellow-800 text-[11px] font-bold px-2 py-1 rounded-full uppercase tracking-wider border border-yellow-200">Pending</span>
                    </td>
                    <td class="px-container-margin py-4">
