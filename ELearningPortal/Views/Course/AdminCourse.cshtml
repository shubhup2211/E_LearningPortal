@using ELearning.Enums
@using ELearning.Models.Authentication
@using ELearning.Models.Courses
@using ELearningPortal.Helpers
@using ELearningPortal.Models.Course
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<partial name="Notification"></partial>

@model CourseView

<!-- Main Content Area -->
<!-- Page Content -->
<div class="p-6 md:p-8 space-y-8">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="font-headline-lg text-headline-lg text-on-surface">Sub Course Management</h1>
            <p class="text-on-surface-variant">Manage and organize your branch's specialized curriculum modules.</p>
        </div>
        <button class="bg-primary-container text-white px-6 py-2.5 rounded-lg font-title-md flex items-center gap-2 hover:bg-primary transition-all shadow-md active:scale-95" onclick="toggleModal('addModal')">
            <span class="material-symbols-outlined">add</span>
            Add Course
        </button>
    </div>
    <!-- Summary Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-primary-fixed rounded-lg">
                    <span class="material-symbols-outlined text-primary">menu_book</span>
                </div>
                <span class="text-tertiary font-medium text-label-md flex items-center">+4.5%</span>
            </div>
            <h3 class="text-on-surface-variant text-label-md">Total Sub Courses</h3>
            <p class="text-3xl font-bold text-on-surface mt-1">892</p>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-tertiary-fixed rounded-lg">
                    <span class="material-symbols-outlined text-tertiary">check_circle</span>
                </div>
                <span class="text-tertiary font-medium text-label-md">Active</span>
            </div>
            <h3 class="text-on-surface-variant text-label-md">Published</h3>
            <p class="text-3xl font-bold text-on-surface mt-1">840</p>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-error-container rounded-lg">
                    <span class="material-symbols-outlined text-error">visibility_off</span>
                </div>
                <span class="text-error font-medium text-label-md">Action Required</span>
            </div>
            <h3 class="text-on-surface-variant text-label-md">Inactive</h3>
            <p class="text-3xl font-bold text-on-surface mt-1">52</p>
        </div>
        <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-shadow">
            <div class="flex justify-between items-start mb-4">
                <div class="p-3 bg-secondary-container rounded-lg">
                    <span class="material-symbols-outlined text-secondary">payments</span>
                </div>
                <span class="text-on-surface-variant text-label-md">Avg Value</span>
            </div>
            <h3 class="text-on-surface-variant text-label-md">Average Price</h3>
            <p class="text-3xl font-bold text-on-surface mt-1">$145.00</p>
        </div>
    </div>
    <!-- Filters & Table Section -->
    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant shadow-sm overflow-hidden">
        <!-- Filter Toolbar -->
        <div class="p-6 border-b border-outline-variant bg-surface-container-low/30">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4">
                <div class="space-y-1">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Search Name</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-sm">search</span>
                        <input class="w-full pl-9 pr-3 py-2 border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-white" placeholder="Filter by name..." type="text" />
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Master Course</label>
                    <select class="w-full px-3 py-2 border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-white appearance-none">
                        <option>All Approved Courses</option>
                        <option>Full Stack Java</option>
                        <option>Python Full Stack</option>
                        <option>MERN Stack</option>
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Status</label>
                    <select class="w-full px-3 py-2 border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-white">
                        <option>All Statuses</option>
                        <option>Active</option>
                        <option>Inactive</option>
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Price Range</label>
                    <div class="flex items-center gap-2">
                        <input class="w-1/2 px-3 py-2 border border-outline-variant rounded-lg text-body-md bg-white" placeholder="Min" type="number" />
                        <span class="text-outline">-</span>
                        <input class="w-1/2 px-3 py-2 border border-outline-variant rounded-lg text-body-md bg-white" placeholder="Max" type="number" />
                    </div>
                </div>
                <div class="flex items-end gap-2 xl:col-span-1 lg:col-span-4">
                    <button class="flex-1 bg-surface-container-high text-on-surface font-semibold py-2 px-4 rounded-lg hover:bg-outline-variant transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-sm">filter_alt</span> Apply
                    </button>
                    <button class="p-2 text-on-surface-variant hover:bg-surface-variant rounded-lg border border-outline-variant">
                        <span class="material-symbols-outlined">refresh</span>
                    </button>
                </div>
            </div>
        </div>
        <!-- Data Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low text-on-surface-variant text-label-md font-bold uppercase tracking-widest border-b border-outline-variant">
                        <th class="px-6 py-4">Image</th>
                        <th class="px-6 py-4">Course Name</th>
                        <th class="px-6 py-4">Branch Name</th>
                        <th class="px-6 py-4">Created By</th>
                        <th class="px-6 py-4">Approval Status</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Created Date</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant">
                    @foreach (var item in Model.coursesList)
                    {
                        <!-- Row 1 -->
                        <tr class="hover:bg-surface-container-low/50 transition-colors">
                            <td class="px-6 py-4">
                                <img class="w-12 h-12 rounded-lg object-cover border border-outline-variant shadow-sm" src="~/@item.Image" />
                            </td>
                            <td class="px-6 py-4">
                                <div class="font-bold text-on-surface">@item.CourseName</div>
                                <div class="text-xs text-on-surface-variant truncate w-48">@item.Description</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 bg-primary-fixed text-on-primary-fixed-variant text-xs font-bold rounded-full">@item.Branch?.BranchName</span>
                            </td>
                            <td class="px-6 py-4 font-bold text-on-surface">@item.CreatedByUser?.FullName</td>
                            <td class="px-6 py-4">
                                @if (item.ApprovalStatus == ApprovalStatus.Approved)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-green-100 text-green-700 text-label-md font-bold">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                        Approved
                                    </span>
                                }
                                @if (item.ApprovalStatus == ApprovalStatus.Pending)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 text-xs font-bold uppercase">
                                        <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
                                        Pending
                                    </span>
                                }
                                @if (item.ApprovalStatus == ApprovalStatus.Rejected)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-error-container/20 text-error text-xs font-bold uppercase">
                                        <span class="w-1.5 h-1.5 rounded-full bg-error"></span>
                                        Rejected
                                    </span>
                                }
                                
                            </td>
                            <td class="px-6 py-4">
                                @if (item.Status == Status.Active)
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-green-100 text-green-700 text-label-md font-bold">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-600"></span>
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-red-100 text-red-700 text-label-md font-bold">
                                        <span class="w-1.5 h-1.5 rounded-full bg-red-600"></span>
                                        Inactive
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant text-sm">@item.CreatedAt</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex justify-end gap-2">
                                    <a class="p-2 hover:bg-secondary-container rounded-lg text-secondary transition-colors" title="Edit" asp-controller="Course" asp-action="EditCourse" asp-route-id="@item.CourseId">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <a class="p-2 hover:bg-error-container rounded-lg text-error transition-colors" title="Delete" asp-controller="Course" asp-action="DeleteCourse" asp-route-id="@item.CourseId" onclick="return confirm('Are you sure you want to delete this Course?');">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="p-6 border-t border-outline-variant flex items-center justify-between">
            <p class="text-sm text-on-surface-variant">Showing 1 to 3 of 892 entries</p>
            <div class="flex gap-2">
                <button class="px-4 py-2 text-sm font-semibold border border-outline-variant rounded-lg hover:bg-surface-container transition-colors disabled:opacity-50" disabled="">Previous</button>
                <button class="px-4 py-2 text-sm font-semibold bg-primary text-white rounded-lg shadow-sm">1</button>
                <button class="px-4 py-2 text-sm font-semibold border border-outline-variant rounded-lg hover:bg-surface-container transition-colors">2</button>
                <button class="px-4 py-2 text-sm font-semibold border border-outline-variant rounded-lg hover:bg-surface-container transition-colors">3</button>
                <span class="px-2 self-center">...</span>
                <button class="px-4 py-2 text-sm font-semibold border border-outline-variant rounded-lg hover:bg-surface-container transition-colors">Next</button>
            </div>
        </div>
    </div>
</div>
<!-- Modals & Drawers -->
<!-- Add/Edit Modal (Large Centered) -->
<div class="fixed inset-0 z-[60] hidden flex items-center justify-center p-4" id="addModal">
    <div class="absolute inset-0 bg-on-background/60 backdrop-blur-sm" onclick="toggleModal('addModal')"></div>
    <div class="relative bg-surface-container-lowest w-full max-w-4xl rounded-2xl shadow-2xl overflow-hidden max-h-[921px] flex flex-col">
        <div class="px-8 py-6 border-b border-outline-variant flex items-center justify-between sticky top-0 bg-surface-container-lowest z-10">
            <div>
                <h2 class="text-2xl font-bold text-on-surface">Add New Course</h2>
                <p class="text-on-surface-variant">Create a new module under an approved Master Course.</p>
            </div>
            <button class="p-2 hover:bg-surface-variant rounded-full transition-colors" onclick="toggleModal('addModal')">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8 overflow-y-auto custom-scrollbar">
            <form asp-action="AdminCourse" asp-controller="Course" method="post" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Left Column -->
                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">Course Name</label>
                        <input asp-for="CourseName" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none" placeholder="e.g., Reactive Spring Microservices" type="text" />
                        <span asp-validation-for="CourseName" class="text-danger"></span>
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">Branch Name</label>
                        <select asp-for="BranchId"  class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none">
                            <option value="@User.GetBranchId()">@User.GetBranchName()</option>
                        </select>
                        <span asp-validation-for="BranchId" class="text-danger"></span>
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">Description</label>
                        <textarea asp-for="Description" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none resize-none" placeholder="Detailed module overview..." rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <!-- Right Column -->
                <div class="space-y-6">
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="font-bold text-sm text-on-surface-variant">Created By</label>
                            <select asp-for="CreatedBy"  class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none">
                                <option value="@User.GetUserId()">@User.GetFullName()</option>
                            </select>
                            <span asp-validation-for="CreatedBy" class="text-danger"></span>
                        </div>
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">Thumbnail Image</label>
                        <div class="border-2 border-dashed border-outline-variant rounded-2xl p-8 flex flex-col items-center justify-center bg-surface-container-low hover:bg-surface-variant/30 transition-colors cursor-pointer relative overflow-hidden group">
                                <input asp-for="UploadedCImage" class="absolute inset-0 opacity-0 cursor-pointer" name="UploadedCImage" type="file" />
                            <span asp-validation-for="UploadedCImage" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">ApprovalStatus</label>
                        <select asp-for="ApprovalStatus" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none">
                            <option value="0">Pending</option>
                        </select>
                        <span asp-validation-for="ApprovalStatus" class="text-danger"></span>
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-sm text-on-surface-variant">Status</label>
                        <select asp-for="Status" class="w-full px-4 py-2.5 border border-outline-variant rounded-xl bg-surface-container-low focus:ring-2 focus:ring-primary focus:border-transparent outline-none">
                            <option value="1">Active</option>
                            <option value="0">Inactive</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    </div>
                </div>

                <div class="px-8 py-6 border-t border-outline-variant flex justify-end gap-4 bg-surface-container-lowest">
                    <button class="px-6 py-2.5 rounded-lg border border-outline text-on-surface font-semibold hover:bg-surface-container-high transition-colors" onclick="toggleModal('addModal')">Cancel</button>
                    <button type="submit" class="px-8 py-2.5 rounded-lg bg-primary text-white font-bold shadow-lg hover:bg-primary-container active:scale-95 transition-all">Create Course</button>
                </div>
            </form>
        </div>

    </div>
</div>
<!-- Edit Modal (Placeholder - shared structure with Add) -->
<div class="fixed inset-0 z-[60] hidden flex items-center justify-center p-4" id="editModal">
    <div class="absolute inset-0 bg-on-background/60 backdrop-blur-sm" onclick="toggleModal('editModal')"></div>
    <div class="relative bg-surface-container-lowest w-full max-w-4xl rounded-2xl p-8 shadow-2xl">
