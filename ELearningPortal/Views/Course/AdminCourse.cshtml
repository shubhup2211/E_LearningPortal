                <div class="bg-surface-container p-4 rounded-xl">
                    <p class="text-xs text-on-surface-variant uppercase font-bold tracking-wider">Enrollments</p>
                    <p class="text-2xl font-bold text-on-surface mt-1">1,402</p>
                </div>
                <div class="bg-surface-container p-4 rounded-xl">
