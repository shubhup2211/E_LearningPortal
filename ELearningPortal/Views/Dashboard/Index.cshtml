@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">

    <!-- Welcome -->
    <div class="mb-4">
        <small class="text-muted">
            Welcome back, <strong>Roshan</strong> 👋
        </small>
        <h2 class="fw-bold mt-2">Your Dashboard</h2>
    </div>

    <!-- Statistics -->
    <div class="row g-4 mb-5">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h2 class="fw-bold text-primary">4</h2>
                    <small class="text-uppercase text-muted">
                        Courses In Progress
                    </small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h2 class="fw-bold text-success">35%</h2>
                    <small class="text-uppercase text-muted">
                        Avg Completion
                    </small>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h2 class="fw-bold text-danger">1</h2>
                    <small class="text-uppercase text-muted">
                        Courses Completed
                    </small>
                </div>
            </div>
        </div>

    </div>

    <!-- Continue Learning -->

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h3 class="fw-bold">Continue Learning</h3>
            <p class="text-muted mb-0">
                Resume your enrolled courses and continue learning.
            </p>
        </div>

        <a href="#" class="btn btn-outline-primary rounded-pill">
            View All
        </a>

    </div>

    <div class="row g-4">

        <!-- Java -->

        <div class="col-lg-6">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/java.jpg"
                             class="img-fluid h-100 w-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-primary-subtle text-primary rounded-pill">
                                    Programming
                                </span>

                                <small class="text-muted">
                                    50% Complete
                                </small>

                            </div>

                            <h4 class="fw-bold mt-3">
                                Java
                            </h4>

                            <p class="text-muted small flex-grow-1">
                                Master Java Programming from beginner to advanced with hands-on projects.
                            </p>

                            <div class="progress mb-3" style="height:7px;">
                                <div class="progress-bar bg-success"
                                     style="width:50%;">
                                </div>
                            </div>

                            <div class="d-flex gap-2">

                                <button class="btn btn-primary flex-fill rounded-pill">
                                    Resume Course
                                </button>

                                <button class="btn btn-success rounded-pill px-4">
                                    Complete
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Python -->

        <div class="col-lg-6">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/python.jpg"
                             class="img-fluid h-100 w-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-warning-subtle text-warning rounded-pill">
                                    Python
                                </span>

                                <small class="text-muted">
                                    20% Complete
                                </small>

                            </div>

                            <h4 class="fw-bold mt-3">
                                Python
                            </h4>

                            <p class="text-muted small flex-grow-1">
                                Learn Python Programming, Automation, Machine Learning and Web Development.
                            </p>

                            <div class="progress mb-3" style="height:7px;">
                                <div class="progress-bar bg-info"
                                     style="width:20%;">
                                </div>
                            </div>

                            <div class="d-flex gap-2">

                                <button class="btn btn-primary flex-fill rounded-pill">
                                    Resume Course
                                </button>

                                <button class="btn btn-success rounded-pill px-4">
                                    Complete
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- .NET -->

        <div class="col-lg-6">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/dotnet.jpg"
                             class="img-fluid h-100 w-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                    .NET
                                </span>

                                <small class="text-muted">
                                    75% Complete
                                </small>

                            </div>

                            <h4 class="fw-bold mt-3">
                                ASP.NET Core
                            </h4>

                            <p class="text-muted small flex-grow-1">
                                Learn MVC, Web API, Entity Framework Core and SQL Server.
                            </p>

                            <div class="progress mb-3" style="height:7px;">
                                <div class="progress-bar bg-primary"
                                     style="width:75%;">
                                </div>
                            </div>

                            <div class="d-flex gap-2">

                                <button class="btn btn-primary flex-fill rounded-pill">
                                    Resume Course
                                </button>

                                <button class="btn btn-success rounded-pill px-4">
                                    Complete
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- Test -->

        <div class="col-lg-6">

            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/course1.jpg"
                             class="img-fluid h-100 w-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-danger-subtle text-danger rounded-pill">
                                    Engineering
                                </span>

                                <small class="text-muted">
                                    0% Complete
                                </small>

                            </div>

                            <h4 class="fw-bold mt-3">
                                Test Course
                            </h4>

                            <p class="text-muted small flex-grow-1">
                                Introduction course for testing and demonstration purposes.
                            </p>

                            <div class="progress mb-3" style="height:7px;">
                                <div class="progress-bar"
                                     style="width:0%;">
                                </div>
                            </div>

                            <div class="d-flex gap-2">

                                <button class="btn btn-primary flex-fill rounded-pill">
                                    Resume Course
                                </button>

                                <button class="btn btn-success rounded-pill px-4">
                                    Complete
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>