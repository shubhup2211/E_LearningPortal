@{
    ViewData["Title"] = "Completed Courses";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Completed Courses</h2>
            <p class="text-muted mb-0">
                Congratulations! Here are all the courses you've successfully completed.
            </p>
        </div>

        <span class="badge bg-success fs-6 px-3 py-2">
            ✔ 4 Courses Completed
        </span>

    </div>

    <div class="row g-4">

        <!-- Java -->
        <div class="col-lg-6">
            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/java.jpg"
                             class="img-fluid w-100 h-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-primary-subtle text-primary rounded-pill">
                                    Programming
                                </span>

                                <span class="badge bg-success rounded-pill">
                                    ✔ Completed
                                </span>

                            </div>

                            <h4 class="mt-3 fw-bold">Java</h4>

                            <p class="text-muted small flex-grow-1">
                                Master Java Programming from beginner to advanced including OOP, Collections and JDBC.
                            </p>

                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar bg-success" style="width:100%;"></div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center">

                                <strong class="text-success">
                                    100% Completed
                                </strong>

                                <button class="btn btn-success rounded-pill">
                                    View Certificate
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>

        <!-- Python -->

        <div class="col-lg-6">
            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/python.jpg"
                             class="img-fluid w-100 h-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-warning-subtle text-warning rounded-pill">
                                    Python
                                </span>

                                <span class="badge bg-success rounded-pill">
                                    ✔ Completed
                                </span>

                            </div>

                            <h4 class="mt-3 fw-bold">Python</h4>

                            <p class="text-muted small flex-grow-1">
                                Learn Python for Web Development, Automation, Data Science and AI.
                            </p>

                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar bg-success" style="width:100%;"></div>
                            </div>

                            <div class="d-flex justify-content-between">

                                <strong class="text-success">
                                    100% Completed
                                </strong>

                                <button class="btn btn-success rounded-pill">
                                    View Certificate
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>

        <!-- ASP.NET -->

        <div class="col-lg-6">
            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/dotnet.jpg"
                             class="img-fluid w-100 h-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-info-subtle text-info rounded-pill">
                                    ASP.NET
                                </span>

                                <span class="badge bg-success rounded-pill">
                                    ✔ Completed
                                </span>

                            </div>

                            <h4 class="mt-3 fw-bold">ASP.NET Core</h4>

                            <p class="text-muted small flex-grow-1">
                                Build secure MVC and Web API applications using Entity Framework Core.
                            </p>

                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar bg-success" style="width:100%;"></div>
                            </div>

                            <div class="d-flex justify-content-between">

                                <strong class="text-success">
                                    100% Completed
                                </strong>

                                <button class="btn btn-success rounded-pill">
                                    View Certificate
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>

        <!-- Test -->

        <div class="col-lg-6">
            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <div class="row g-0">

                    <div class="col-4">
                        <img src="~/images/course1.jpg"
                             class="img-fluid w-100 h-100"
                             style="object-fit:cover;">
                    </div>

                    <div class="col-8">

                        <div class="card-body d-flex flex-column h-100">

                            <div class="d-flex justify-content-between">

                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                    Engineering
                                </span>

                                <span class="badge bg-success rounded-pill">
                                    ✔ Completed
                                </span>

                            </div>

                            <h4 class="mt-3 fw-bold">Engineering Basics</h4>

                            <p class="text-muted small flex-grow-1">
                                Learn engineering fundamentals and complete practical exercises.
                            </p>

                            <div class="progress mb-3" style="height:8px;">
                                <div class="progress-bar bg-success" style="width:100%;"></div>
                            </div>

                            <div class="d-flex justify-content-between">

                                <strong class="text-success">
                                    100% Completed
                                </strong>

                                <button class="btn btn-success rounded-pill">
                                    View Certificate
                                </button>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        </div>

    </div>

</div>