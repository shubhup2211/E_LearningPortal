@{
    ViewData["Title"] = "My Courses";
}

<div class="container py-4">

    <!-- Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">All Courses</h2>
            <p class="text-muted mb-0">
                Browse the full library of professional learning content.
            </p>
        </div>

        <div>
            <select class="form-select rounded-pill shadow-sm">
                <option>Sort: Recent</option>
                <option>Name</option>
                <option>Newest</option>
                <option>Oldest</option>
            </select>
        </div>

    </div>


    <!-- Courses -->

    <div class="row g-4">

        <!-- Card 1 -->

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <img src="~/images/course1.jpg"
                     class="card-img-top"
                     style="height:180px;object-fit:cover;" />

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-3">

                        <span class="badge rounded-pill bg-primary-subtle text-primary">
                            Engineering
                        </span>

                        <small class="text-muted">
                            🕒 15h
                        </small>

                    </div>

                    <h5 class="fw-bold">
                        Test
                    </h5>

                    <p class="text-muted small">
                        Test
                    </p>

                </div>

                <div class="card-footer bg-white border-0">

                    <div class="d-flex justify-content-between align-items-center">

                        <small class="text-muted">
                            1 Lesson
                        </small>

                        <button class="btn btn-primary rounded-pill btn-sm px-3">
                            Resume Course
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- Card 2 -->

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <img src="~/images/dotnet.jpg"
                     class="card-img-top"
                     style="height:180px;object-fit:cover;" />

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-3">

                        <span class="badge rounded-pill bg-primary-subtle text-primary">
                            Programming
                        </span>

                        <small class="text-muted">
                            🕒 6h
                        </small>

                    </div>

                    <h5 class="fw-bold">
                        DOT NET
                    </h5>

                    <p class="text-muted small">
                        Learn ASP.NET Core MVC, Web API, Entity Framework Core and SQL Server.
                    </p>

                </div>

                <div class="card-footer bg-white border-0">

                    <div class="d-flex justify-content-between">

                        <small class="text-muted">
                            10 Lessons
                        </small>

                        <button class="btn btn-primary rounded-pill btn-sm">
                            Resume Course
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- Card 3 -->

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <img src="~/images/python.jpg"
                     class="card-img-top"
                     style="height:180px;object-fit:cover;" />

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-3">

                        <span class="badge rounded-pill bg-primary-subtle text-primary">
                            Python
                        </span>

                        <small class="text-muted">
                            🕒 3h 20m
                        </small>

                    </div>

                    <h5 class="fw-bold">
                        Python
                    </h5>

                    <p class="text-muted small">
                        Build automation scripts, web applications, AI and machine learning projects.
                    </p>

                </div>

                <div class="card-footer bg-white border-0">

                    <div class="d-flex justify-content-between">

                        <small class="text-muted">
                            10 Lessons
                        </small>

                        <button class="btn btn-primary rounded-pill btn-sm">
                            Resume Course
                        </button>

                    </div>

                </div>

            </div>

        </div>

        <!-- Card 4 -->

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <img src="~/images/java.jpg"
                     class="card-img-top"
                     style="height:180px;object-fit:cover;" />

                <div class="card-body">

                    <div class="d-flex justify-content-between mb-3">

                        <span class="badge rounded-pill bg-primary-subtle text-primary">
                            Java
                        </span>

                        <small class="text-muted">
                            🕒 5h 30m
                        </small>

                    </div>

                    <h5 class="fw-bold">
                        Java
                    </h5>

                    <p class="text-muted small">
                        Learn Java from basic to advanced including Spring Boot and REST APIs.
                    </p>

                </div>

                <div class="card-footer bg-white border-0">

                    <div class="d-flex justify-content-between">

                        <small class="text-muted">
                            10 Lessons
                        </small>

                        <button class="btn btn-primary rounded-pill btn-sm">
                            Resume Course
                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>