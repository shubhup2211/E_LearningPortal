@{
    ViewData["Title"] = "My Courses";
}
@model List<ELearning.Models.Courses.Course>


<div class="container py-4">

    <!-- Heading -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">All Courses</h2>
            <p class="text-muted mb-0">
                Browse the full library of professional learning content.
            </p>
        </div>

        <div>
            <select class="form-select rounded-pill shadow-sm">
                <option>Sort: Recent</option>
                <option>Name</option>
                <option>Newest</option>
                <option>Oldest</option>
            </select>
        </div>

    </div>


    <!-- Courses -->

    <div class="row g-4">

        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-6">

                <div class="card border-0 shadow-sm rounded-4 h-100">

                    <img src="~/images/courses/@item.Image"
                         class="card-img-top"
                         style="height:180px;object-fit:cover;" />

                    <div class="card-body">

                        <div class="d-flex justify-content-between mb-3">

                            <span class="badge rounded-pill bg-primary-subtle text-primary">
                                @item.Branch.BranchName
                            </span>

                            <small class="text-muted">
                                🕒 10h
                            </small>

                        </div>

                        <h5 class="fw-bold">
                            @item.CourseName
                        </h5>

                        <p class="text-muted small">
                            @item.Description
                        </p>

                        <h4>Price:$999</h4>

                        <h3>Rating: * * * * *</h3>
                    </div>

                    <div class="card-footer bg-white border-0">

                        <div class="d-flex justify-content-between align-items-center">

                            <small class="text-muted">
                                @item.SubCourses.Count Lesson
                            </small>

                            <button class="btn btn-primary rounded-pill btn-sm px-3">
                                Buy Course
                            </button>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>