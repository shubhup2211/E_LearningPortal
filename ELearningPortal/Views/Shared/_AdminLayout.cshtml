<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lumina Admin</title>
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://jsdelivr.net" />

    <style>
        :root {
            --primary-purple: #8a2be2;
            --main-bg: #f8f9fa;
        }

        body {
            background-color: var(--main-bg);
        }

        .admin-container {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 260px;
            min-width: 260px;
        }

        .nav-pills .nav-link.active {
            background-color: var(--primary-purple);
            color: white;
            border-radius: 8px;
        }

        .nav-link {
            color: #6c757d;
            font-weight: 500;
        }

            .nav-link:hover {
                color: var(--primary-purple);
            }
    </style>
</head>
<body>

    <div class="admin-container">

        <!-- LEFT SIDEBAR -->
        <aside class="bg-white border-end d-flex flex-column justify-content-between p-3 admin-sidebar">
            <div>
                <!-- Brand Headers -->
                <div class="d-flex align-items-center mb-4 px-2 pt-2">
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center rounded-circle me-2" style="width: 32px; height: 32px;">
                        <i class="bi bi-cloud-fill"></i>
                    </div>
                    <div>
                        <h6 class="m-0 fw-bold text-primary">Lumina</h6>
                        <small class="text-muted d-block" style="font-size: 11px;">Premium LMS Admin</small>
                    </div>
                </div>

                <!-- Navigation Options Links -->
                <ul class="nav nav-pills flex-column gap-1">
                    <li class="nav-item">
                        <a asp-controller="Courses" asp-action="Index" class="nav-link active">
                            <i class="bi bi-grid-fill me-2"></i> Courses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a asp-controller="User" asp-action="Index" class="nav-link">
                            <i class="bi bi-people-fill me-2"></i> Users
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Bottom Exit Action -->
            <div>
                <hr class="text-muted">
                <a href="#" class="nav-link text-danger px-2">
                    <i class="bi bi-box-arrow-left me-2"></i> Sign Out
                </a>
            </div>
        </aside>

        <!-- RIGHT WORKSPACE BOX -->
        <div class="flex-grow-1 d-flex flex-column">

            <!-- Contextual Search Header Bar -->
            <header class="bg-white border-bottom px-4 py-2 d-flex justify-content-between align-items-center" style="height: 60px;">
                <div><!-- Alignment Spacer --></div>
                <div class="d-flex align-items-center gap-3">
                    <input type="text" class="form-control form-control-sm rounded-pill bg-light border-0 px-3" placeholder="Search lessons..." style="width: 220px;">
                    <i class="bi bi-bell text-muted"></i>
                    <span class="small fw-semibold text-secondary">Admin User</span>
                </div>
            </header>

            <!-- CANVAS INTERIOR VIEWS ENTRY POINT -->
            <main class="p-4 flex-grow-1">
                @RenderBody()
            </main>

            <!-- Admin Footer Elements -->
            <footer class="bg-white border-top py-3 px-4 d-flex justify-content-between align-items-center text-muted small">
                <div>Lumina Learning &copy; 2026 Admin Panel</div>
                <div class="d-flex gap-3">
                    <a href="#" class="text-decoration-none text-muted">Privacy Policy</a>
                    <a href="#" class="text-decoration-none text-muted">Documentation</a>
                </div>
            </footer>
        </div>

    </div>

    <!-- Core Runtime Scripts Injection -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

