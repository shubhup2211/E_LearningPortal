<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - ELearning Portal</title>

    <!-- Bootstrap -->
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

    <!-- Site CSS -->
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />

    <style>

            body {
                background: #f5f7fb;
                font-family: "Segoe UI",sans-serif;
            }

            .main-navbar {
                background: #fff;
                box-shadow: 0 2px 12px rgba(0,0,0,.05);
                padding: 12px 0;
                position: sticky;
                top: 0;
                z-index: 999;
            }

            .logo-box {
                width:40px;
                height:40px;
                border-radius:10px;
                background:#4f46e5;
                color:#fff;
                display:flex;
                align-items:center;
                justify-content:center;
                font-weight:bold;
                margin-right:10px;
            }

            .brand-text{
                font-size:22px;
                font-weight:700;
                color:#111827;
            }

            .nav-center .nav-link{
                color:#6b7280;
                margin:0 8px;
                font-weight:500;
                border-radius:20px;
                padding:8px 18px;
                transition:.3s;
            }

            .nav-center .nav-link:hover{
                background:#eef2ff;
                color:#4f46e5;
            }

            .nav-center .active{
                background:#eef2ff;
                color:#4f46e5!important;
            }

            .profile-avatar{
                width:42px;
                height:42px;
                border-radius:50%;
                background:#4f46e5;
                color:white;
                display:flex;
                align-items:center;
                justify-content:center;
                font-weight:700;
            }

            main{
                min-height:calc(100vh - 130px);
                padding-top:30px;
            }

            footer{
                background:white;
                border-top:1px solid #eee;
                padding:15px 0;
                text-align:center;
                color:#777;
            }

    </style>

</head>
<body>

    <header class="main-navbar">

        <div class="container">

            <div class="d-flex justify-content-between align-items-center">

                <!-- Logo -->

                <div class="d-flex align-items-center">

                    <div class="logo-box">
                        E
                    </div>

                    <span class="brand-text">
                        ELearning
                    </span>

                </div>


                <!-- Center Menu -->

                <ul class="nav nav-center">

                    <li class="nav-item">
                        <a class="nav-link active"
                           asp-controller="User"
                           asp-action="Dashboard">
                            Dashboard
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Course"
                           asp-action="Index">
                            Courses
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="LearningPath"
                           asp-action="Index">
                            Learning Paths
                        </a>
                    </li>

                </ul>


                <!-- Right -->

                <div class="d-flex align-items-center">

                    <div class="profile-avatar">
                        A
                    </div>

                </div>

            </div>

        </div>

    </header>


    <main>

        <div class="container">

            @RenderBody()

        </div>

    </main>


    <footer>

        <div class="container">

            © @DateTime.Now.Year ELearning Portal

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>